# --- Apply roster stats to a player ---

fn roster_apply_stats(player, team_id, player_index) {
    if (team_id < 0) { team_id = 0; }
    if (team_id >= TEAM_COUNT) { team_id = TEAM_COUNT - 1; }
    if (player_index < 0) { player_index = 0; }
    if (player_index >= PLAYERS_PER_TEAM) { player_index = PLAYERS_PER_TEAM - 1; }
    var slot = team_id * 2 + player_index;
    player_set_stats(player,
        roster_stat_speed(slot),
        roster_stat_power(slot),
        roster_stat_shooting(slot),
        roster_stat_dunking(slot),
        roster_stat_stealing(slot),
        roster_stat_blocking(slot),
        roster_stat_pass(slot),
        roster_stat_clutch(slot),
        roster_stat_rebound(slot)
    );
}

# --- Team jersey colors (palette indices) ---

fn roster_jersey_primary(team_id) {
    if (team_id == 0) { return 24; }
    if (team_id == 1) { return 16; }
    if (team_id == 2) { return 17; }
    if (team_id == 3) { return 25; }
    if (team_id == 4) { return 18; }
    if (team_id == 5) { return 20; }
    if (team_id == 6) { return 24; }
    if (team_id == 7) { return 10; }
    return 16;
}

fn roster_jersey_secondary(team_id) {
    if (team_id == 0) { return 10; }
    if (team_id == 1) { return 25; }
    if (team_id == 2) { return 24; }
    if (team_id == 3) { return 12; }
    if (team_id == 4) { return 10; }
    if (team_id == 5) { return 48; }
    if (team_id == 6) { return 48; }
    if (team_id == 7) { return 10; }
    return 20;
}

# --- Stat total for display ---

fn roster_team_total(team_id) {
    var total = 0;
    var p = 0;
    while (p < PLAYERS_PER_TEAM) {
        var slot = team_id * 2 + p;
        total = total + roster_stat_speed(slot);
        total = total + roster_stat_power(slot);
        total = total + roster_stat_shooting(slot);
        total = total + roster_stat_dunking(slot);
        total = total + roster_stat_stealing(slot);
        total = total + roster_stat_blocking(slot);
        total = total + roster_stat_pass(slot);
        total = total + roster_stat_clutch(slot);
        total = total + roster_stat_rebound(slot);
        p = p + 1;
    }
    return total;
}
