// cyrius-nba-jam — test suite
// v0.2.0: Tests for physics, fire, stats, render, sprite, court,
// player, ball, collision, shooting, game state, HUD.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"

include "src/types.cyr"
include "src/render.cyr"
include "src/sprite.cyr"
include "src/court.cyr"
include "src/player.cyr"
include "src/ball.cyr"
