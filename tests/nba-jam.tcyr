include "src/shoot.cyr"
include "src/game.cyr"
include "src/hud.cyr"

// ========= Ball physics (from v0.1.0) =========

fn test_ball_arc() {
    var y = 100 * 65536;
    var vy = 0 - (20 * 65536);
    var gravity = BALL_GRAVITY;

    var i = 0;
    while (i < 10) {
        vy = vy + gravity;
        y = y + vy;
        i = i + 1;
    }
    assert(vy > (0 - (20 * 65536)), "gravity slows upward velocity");
    return 0;
}

// ========= Fire mechanic =========

fn test_fire_activation() {
    var consecutive = 3;
    var on_fire = 0;
    if (consecutive >= FIRE_BASKETS_NEEDED) { on_fire = 1; }
    assert(on_fire == 1, "3 consecutive baskets activate fire");
    return 0;
}

fn test_fire_extinguish() {
    var on_fire = 1;
    var opponent_scored = 1;
    if (opponent_scored == 1) { on_fire = 0; }
    assert(on_fire == 0, "opponent scoring extinguishes fire");
    return 0;
}

// ========= Stats =========

fn test_stat_range() {
    var stats[9];
    store64(&stats, 7); store64(&stats + 8, 4); store64(&stats + 16, 9);
    store64(&stats + 24, 8); store64(&stats + 32, 3); store64(&stats + 40, 5);
    store64(&stats + 48, 6); store64(&stats + 56, 10); store64(&stats + 64, 5);

    var i = 0;
    while (i < STAT_COUNT) {
        var val = load64(&stats + i * 8);
        assert(val >= 1, "stat >= 1");
        assert(val <= 10, "stat <= 10");
        i = i + 1;
    }
    return 0;
}

// ========= Render =========

fn test_fb_clear() {
    render_init();
    fb_clear(42);
    assert_eq(fb_get(0, 0), 42, "clear fills (0,0)");
    assert_eq(fb_get(160, 120), 42, "clear fills center");
    fb_clear(0);
    return 0;
}

fn test_fb_set_get() {
    render_init();
    fb_clear(0);
    fb_set(100, 100, 7);
    assert_eq(fb_get(100, 100), 7, "set/get pixel");
    assert_eq(fb_get(101, 100), 0, "adjacent unchanged");
    return 0;
}

fn test_fb_bounds() {
    render_init();
    fb_clear(0);
    assert_eq(fb_get(-1, 0), 0, "neg x returns 0");
    assert_eq(fb_get(320, 0), 0, "x >= W returns 0");
    fb_set(-1, 0, 99);
    fb_set(320, 0, 99);
    return 0;
}

fn test_draw_hline() {
    render_init();
    fb_clear(0);
    draw_hline(10, 20, 50, 8);
    assert_eq(fb_get(10, 50), 8, "hline start");
    assert_eq(fb_get(20, 50), 8, "hline end");
    assert_eq(fb_get(9, 50), 0, "hline before");
    return 0;
}

fn test_palette() {
    render_init();
    assert_eq(pal_get_r(0), 0, "palette 0 R=0");
    assert_eq(pal_get_r(63), 255, "palette 63 R=255");
    return 0;
}

// ========= Sprite =========

fn test_sprite_blit() {
    render_init();
    fb_clear(0);
    var data[16];
    memset(&data, 0, 16);
    store8(&data + 5, 2);
    var spr = Sprite { &data, 4, 4 };
    sprite_blit(&spr, 10, 10);
    assert_eq(fb_get(11, 11), 2, "sprite blit writes pixel");
    assert_eq(fb_get(10, 10), 0, "transparent pixel unchanged");
    return 0;
}

fn test_sprite_make_player() {
    var buf[384];
    sprite_make_player(&buf, 16, 24, 16, 20);
    var body = load8(&buf + 12 * 16 + 8);
    assert_eq(body, 16, "player body is jersey");
    return 0;
}

// ========= Court =========

fn test_court_screen_y() {
    var far_y = court_game_to_screen_y(COURT_FAR);
    assert_eq(far_y, 40, "far -> screen top");
    var near_y = court_game_to_screen_y(COURT_NEAR);
    assert_eq(near_y, 210, "near -> screen bottom");
    return 0;
}

fn test_court_scale() {
    var far_scale = court_scale_at_y(COURT_FAR);
    assert_eq(far_scale, 32768, "far scale 0.5");
    var near_scale = court_scale_at_y(COURT_NEAR);
    assert(near_scale > 60000, "near scale ~1.0");
    return 0;
}

// ========= Player state machine =========

fn test_player_committed() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_try_transition(p, PS_SHOOT);
    var ptr: *i64 = p;
    assert_eq(*(ptr + 4), PS_SHOOT, "entered shoot");
    player_try_transition(p, PS_RUN);
    assert_eq(*(ptr + 4), PS_SHOOT, "shoot rejects input");
    return 0;
}

fn test_player_timer_expiry() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_try_transition(p, PS_SHOOT);
    var i = 0;
    while (i < 30) { player_tick_state(p); i = i + 1; }
    var ptr: *i64 = p;
    assert_eq(*(ptr + 4), PS_IDLE, "shoot -> idle after timer");
    return 0;
}

fn test_player_movement() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_set_stats(p, 7, 5, 8, 6, 4, 5, 6, 7, 5);
    var ptr: *i64 = p;
    var initial_x = *ptr;
    var i = 0;
    while (i < 10) {
        player_apply_input(p, 1, 0, 0);
        player_update(p);
        i = i + 1;
    }
    assert(*ptr > initial_x, "player moved right");
    return 0;
}

fn test_player_court_bounds() {
    var p = player_new(TEAM_HOME, 0, COURT_RIGHT, 8519680);
    var ptr: *i64 = p;
    *(ptr + 2) = 65536;
    player_update(p);
    assert_eq(*ptr, COURT_RIGHT, "clamped to court right");
    return 0;
}

// ========= Ball =========

fn test_ball_new() {
    var b = ball_new(6553600, 8519680);
    var bp: *i64 = b;
    assert_eq(*(bp + 6), BALL_HELD, "ball starts held");
    assert_eq(*(bp + 2), BALL_HOLD_Z, "ball at hold height");
    return 0;
}

fn test_ball_launch() {
    var b = ball_new(6553600, 8519680);
    ball_launch(b, 65536, 32768, 131072);
    var bp: *i64 = b;
    assert_eq(*(bp + 6), BALL_FLIGHT, "ball in flight after launch");
    assert_eq(*(bp + 3), 65536, "vx set");
    assert_eq(*(bp + 5), 131072, "vz set");
    return 0;
}

fn test_ball_gravity() {
    var b = ball_new(6553600, 8519680);
    ball_launch(b, 0, 0, 131072);   // straight up

    var bp: *i64 = b;
    var initial_vz = *(bp + 5);

    // Step a few frames
    var i = 0;
    while (i < 5) {
        ball_physics_step(b);
        i = i + 1;
    }

    // vz should have decreased (gravity pulls down)
    assert(*(bp + 5) < initial_vz, "gravity reduces vz");
    return 0;
}

fn test_ball_floor_bounce() {
    var b = ball_new(6553600, 8519680);
    var bp: *i64 = b;
    // Put ball at floor with downward velocity
    *(bp + 2) = 0;              // z = floor
    *(bp + 5) = 0 - 65536;     // vz = -1.0 (downward)
    *(bp + 6) = BALL_FLIGHT;

    ball_floor_check(b);

    // vz should be positive (bounced)
    assert(*(bp + 5) >= 0, "vz positive after floor bounce");
    assert_eq(*(bp + 2), 0, "z at floor after bounce");
    return 0;
}

fn test_ball_give_to() {
    var b = ball_new(6553600, 8519680);
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    ball_give_to(b, p);

    var bp: *i64 = b;
    assert_eq(*(bp + 6), BALL_HELD, "ball held after give");
    assert_eq(*(bp + 7), p, "holder set");

    var pp: *i64 = p;
    assert_eq(*(pp + 9), 1, "player has_ball");
    return 0;
}

fn test_ball_held_follows_player() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var b = ball_new(0, 0);
    ball_give_to(b, p);
    ball_update(b);

    var bp: *i64 = b;
    var pp: *i64 = p;
    // Ball should be near player position
    var dx = *bp - *pp;
    if (dx < 0) { dx = 0 - dx; }
    assert(dx < 327680, "ball follows player x");   // within 5.0
    return 0;
}

// ========= Collision =========

fn test_dist_sq() {
    var d = dist_sq(0, 0, 196608, 262144);   // (0,0) to (3,4)
    assert(d > 0, "dist_sq positive for 3-4-5 triangle");
    return 0;
}

fn test_ball_player_pickup() {
    var b = ball_new(6553600, 8519680);
    var bp: *i64 = b;
    *(bp + 6) = BALL_BOUNCE;     // loose ball
    *(bp + 2) = 0;               // on floor

    // Player right on top of ball
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var result = collision_ball_player(b, p);
    assert_eq(result, 1, "player picks up nearby ball");
    assert_eq(*(bp + 6), BALL_HELD, "ball now held");
    return 0;
}

fn test_ball_player_too_far() {
    var b = ball_new(6553600, 8519680);
    var bp: *i64 = b;
    *(bp + 6) = BALL_BOUNCE;
    *(bp + 2) = 0;

    // Player far away
    var p = player_new(TEAM_HOME, 0, 14417920, 8519680);  // (220, 130)
    var result = collision_ball_player(b, p);
    assert_eq(result, 0, "no pickup when far away");
    return 0;
}

// ========= Shooting =========

fn test_shoot_rng_determinism() {
    shoot_rng_seed(42);
    var a = shoot_rng();
    shoot_rng_seed(42);
    var b = shoot_rng();
    assert_eq(a, b, "same seed -> same value");
    return 0;
}

fn test_compute_shot() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    compute_shot(p, RIM_RIGHT_X, RIM_Y);

    // vx should be positive (shooting right)
    assert(_shot_vx > 0, "shot vx positive toward right rim");
    // vz should be positive (ball goes up)
    assert(_shot_vz > 0, "shot vz positive (upward arc)");
    return 0;
}

fn test_three_pointer() {
    // Close player: not a three
    var p_close = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 655360, RIM_Y);
    assert_eq(is_three_pointer(p_close, RIM_RIGHT_X, RIM_Y), 0, "close = 2pt");

    // Far player: three-pointer
    var p_far = player_new(TEAM_HOME, 0, 6553600, 8519680);  // (100, 130)
    assert_eq(is_three_pointer(p_far, RIM_RIGHT_X, RIM_Y), 1, "far = 3pt");
    return 0;
}

// ========= Game state =========

fn test_game_new() {
    var g = game_new();
    var gp: *i64 = g;
    assert_eq(*gp, STATE_TIPOFF, "game starts in tipoff");
    assert_eq(*(gp + 1), 1, "quarter 1");
    assert_eq(*(gp + 4), 0, "home score 0");
    assert_eq(*(gp + 5), 0, "away score 0");
    return 0;
}

fn test_game_tipoff_to_playing() {
    var g = game_new();
    var gp: *i64 = g;

    // Tick through tipoff
    var i = 0;
    while (i < TIPOFF_FRAMES + 1) {
        game_update_tipoff(g);
        i = i + 1;
    }
    assert_eq(*gp, STATE_PLAYING, "tipoff -> playing");
    return 0;
}

fn test_game_clock_seconds() {
    var g = game_new();
    var gp: *i64 = g;
    *(gp + 2) = 3600;    // 60 seconds * 60 fps
    assert_eq(game_clock_seconds(g), 60, "clock_seconds = 60");
    return 0;
}

fn test_game_turnover() {
    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_PLAYING;
    *(gp + 6) = TEAM_HOME;

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var p2 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var players[2];
    store64(&players, p1);
    store64(&players + 8, p2);

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, p1);

    game_turnover(g, b, &players, 2);

    assert_eq(*(gp + 6), TEAM_AWAY, "possession changed on turnover");
    return 0;
}

// ========= HUD =========

fn test_hud_digit() {
    render_init();
    fb_clear(0);
    hud_init_font();
    hud_draw_digit(0, 100, 100, 8, 2);

    // Digit "0" at 2x scale: top row = 111 → 6 pixels at (100-105, 100-101)
    assert_eq(fb_get(100, 100), 8, "digit 0 top-left");
    assert_eq(fb_get(104, 100), 8, "digit 0 top-right");
    return 0;
}

fn test_hud_renders() {
    render_init();
    fb_clear(0);

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var players[1];
    store64(&players, p1);

    hud_draw(42, 37, 2, 120, 18, &players, 1);

    // Top bar should have non-zero pixels
    var top_pixel = fb_get(10, 3);
    assert(top_pixel != 0, "HUD renders score area");
    return 0;
}

// ========= Steal =========

fn test_steal_close() {
    var stealer = player_new(TEAM_AWAY, 0, 6619136, 8519680);  // very close to handler
    player_set_stats(stealer, 5, 5, 5, 5, 10, 5, 5, 5, 5);    // max steal stat

    var handler = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var hp: *i64 = handler;
    *(hp + 9) = 1;     // has_ball

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, handler);

    // With steal stat 10, probability is 60%. Try multiple times.
    _steal_rng = 1;     // seed for reproducibility
    var stolen = 0;
    var attempts = 20;
    var i = 0;
    while (i < attempts) {
        // Reset state for each attempt
        ball_give_to(b, handler);
        var result = collision_try_steal(stealer, handler, b);
        if (result == 1) { stolen = stolen + 1; }
        i = i + 1;
    }
    assert(stolen > 0, "steal succeeds at least once in 20 tries with stat 10");
    assert(stolen < attempts, "steal doesn't always succeed");
    return 0;
}

fn test_steal_different_team_only() {
    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var p2 = player_new(TEAM_HOME, 1, 6619136, 8519680);   // same team
    player_set_stats(p1, 5, 5, 5, 5, 10, 5, 5, 5, 5);

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, p2);

    var result = collision_try_steal(p1, p2, b);
    assert_eq(result, 0, "can't steal from teammate");
    return 0;
}

// ========= Block =========

fn test_block_requires_shoot_state() {
    var blocker = player_new(TEAM_AWAY, 0, 6619136, 8519680);
    player_set_stats(blocker, 5, 5, 5, 5, 5, 10, 5, 5, 5);    // max block

    var shooter = player_new(TEAM_HOME, 0, 6553600, 8519680);
    // Shooter NOT in shoot state
    var sp: *i64 = shooter;
    *(sp + 4) = PS_RUN;

    var b = ball_new(6553600, 8519680);
    var result = collision_try_block(blocker, shooter, b);
    assert_eq(result, 0, "can't block non-shooter");
    return 0;
}

// ========= Pass interception =========

fn test_intercept_close() {
    var b = ball_new(10485760, 8519680);    // ball at (160, 130)
    var bp: *i64 = b;
    *(bp + 6) = BALL_FLIGHT;
    *(bp + 2) = 196608;     // z = 3.0 (catchable height)

    // Defender right on the ball path
    var defender = player_new(TEAM_AWAY, 0, 10485760, 8519680);
    var players[1];
    store64(&players, defender);

    var result = collision_check_intercept(b, &players, 1, TEAM_HOME);
    assert_eq(result, 1, "defender intercepts pass");
    assert_eq(*(bp + 6), BALL_HELD, "ball now held by interceptor");
    return 0;
}

fn test_intercept_same_team_ignored() {
    var b = ball_new(10485760, 8519680);
    var bp: *i64 = b;
    *(bp + 6) = BALL_FLIGHT;
    *(bp + 2) = 196608;

    // Same team player — should not intercept
    var teammate = player_new(TEAM_HOME, 1, 10485760, 8519680);
    var players[1];
    store64(&players, teammate);

    var result = collision_check_intercept(b, &players, 1, TEAM_HOME);
    assert_eq(result, 0, "teammate doesn't intercept own pass");
    return 0;
}

// ========= Turbo =========

fn test_turbo_drain() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_set_stats(p, 7, 5, 8, 6, 4, 5, 6, 7, 5);
    var ptr: *i64 = p;
    var initial_turbo = *(ptr + 11);

    // Use turbo for 10 frames
    var i = 0;
    while (i < 10) {
        player_apply_input(p, 1, 0, 1);   // turbo = 1
        player_update(p);
        i = i + 1;
    }

    assert(*(ptr + 11) < initial_turbo, "turbo drains during use");
    return 0;
}

fn test_turbo_fire_infinite() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_set_stats(p, 7, 5, 8, 6, 4, 5, 6, 7, 5);
    var ptr: *i64 = p;
    *(ptr + 10) = 1;    // on_fire
    *(ptr + 11) = 50;   // start at half turbo

    // Use turbo for 10 frames while on fire
    var i = 0;
    while (i < 10) {
        player_apply_input(p, 1, 0, 1);
        i = i + 1;
    }

    // Turbo should not have drained (fire = infinite)
    assert_eq(*(ptr + 11), 50, "fire mode: turbo doesn't drain");
    return 0;
}

// ========= Integration =========

fn test_court_render_pixels() {
    render_init();
    fb_clear(0);
    court_draw();
    var pixels = render_pixel_count();
    assert(pixels > 10000, "court >10000 pixels");
    return 0;
}

fn test_full_frame() {
    render_init();
    fb_clear(0);
    court_draw();

    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var pp: *i64 = p;
    *(pp + 14) = 0;     // no sprite, use fallback
    player_draw(p);

    var b = ball_new(10485760, 6553600);
    ball_draw(b);

    var pixels = render_pixel_count();
    assert(pixels > 12000, "full frame > 12000 pixels");
    return 0;
}

// ========= Main =========

fn main() {
    alloc_init();

    // Physics
    test_ball_arc();

    // Fire
    test_fire_activation();
    test_fire_extinguish();

    // Stats
    test_stat_range();

    // Render
    test_fb_clear();
    test_fb_set_get();
    test_fb_bounds();
    test_draw_hline();
    test_palette();

    // Sprite
    test_sprite_blit();
    test_sprite_make_player();

    // Court
    test_court_screen_y();
    test_court_scale();

    // Player
    test_player_committed();
    test_player_timer_expiry();
    test_player_movement();
    test_player_court_bounds();

    // Ball
    test_ball_new();
    test_ball_launch();
    test_ball_gravity();
    test_ball_floor_bounce();
    test_ball_give_to();
    test_ball_held_follows_player();

    // Collision
    test_dist_sq();
    test_ball_player_pickup();
    test_ball_player_too_far();

    // Shooting
    test_shoot_rng_determinism();
    test_compute_shot();
    test_three_pointer();

    // Game state
    test_game_new();
    test_game_tipoff_to_playing();
    test_game_clock_seconds();
    test_game_turnover();

    // HUD
    test_hud_digit();
    test_hud_renders();

    // Steal
    test_steal_close();
    test_steal_different_team_only();

    // Block
    test_block_requires_shoot_state();

    // Interception
    test_intercept_close();
    test_intercept_same_team_ignored();

    // Turbo
    test_turbo_drain();
    test_turbo_fire_infinite();

    // Integration
    test_court_render_pixels();
    test_full_frame();

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
