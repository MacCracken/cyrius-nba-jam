// ========= Ball physics (from v0.1.0) =========

fn test_ball_arc() {
    var y = 100 * 65536;
    var vy = 0 - (20 * 65536);
    var gravity = BALL_GRAVITY;

    var i = 0;
    while (i < 10) {
        vy = vy + gravity;
        y = y + vy;
        i = i + 1;
    }
    assert(vy > (0 - (20 * 65536)), "gravity slows upward velocity");
    return 0;
}

// ========= Fire mechanic =========

fn test_fire_activation() {
    var consecutive = 3;
    var on_fire = 0;
    if (consecutive >= FIRE_BASKETS_NEEDED) { on_fire = 1; }
    assert(on_fire == 1, "3 consecutive baskets activate fire");
    return 0;
}

fn test_fire_extinguish() {
    var on_fire = 1;
    var opponent_scored = 1;
    if (opponent_scored == 1) { on_fire = 0; }
    assert(on_fire == 0, "opponent scoring extinguishes fire");
    return 0;
}

// ========= Stats =========

fn test_stat_range() {
    var stats[9];
    store64(&stats, 7); store64(&stats + 8, 4); store64(&stats + 16, 9);
    store64(&stats + 24, 8); store64(&stats + 32, 3); store64(&stats + 40, 5);
    store64(&stats + 48, 6); store64(&stats + 56, 10); store64(&stats + 64, 5);

    var i = 0;
    while (i < STAT_COUNT) {
        var val = load64(&stats + i * 8);
        assert(val >= 1, "stat >= 1");
        assert(val <= 10, "stat <= 10");
        i = i + 1;
    }
    return 0;
}

// ========= Render =========

fn test_fb_clear() {
    render_init();
    fb_clear(42);
    assert_eq(fb_get(0, 0), 42, "clear fills (0,0)");
    assert_eq(fb_get(160, 120), 42, "clear fills center");
    fb_clear(0);
    return 0;
}

fn test_fb_set_get() {
    render_init();
    fb_clear(0);
    fb_set(100, 100, 7);
    assert_eq(fb_get(100, 100), 7, "set/get pixel");
    assert_eq(fb_get(101, 100), 0, "adjacent unchanged");
    return 0;
}

fn test_fb_bounds() {
    render_init();
    fb_clear(0);
    assert_eq(fb_get(-1, 0), 0, "neg x returns 0");
    assert_eq(fb_get(320, 0), 0, "x >= W returns 0");
    fb_set(-1, 0, 99);
    fb_set(320, 0, 99);
    return 0;
}

fn test_draw_hline() {
    render_init();
    fb_clear(0);
    draw_hline(10, 20, 50, 8);
    assert_eq(fb_get(10, 50), 8, "hline start");
    assert_eq(fb_get(20, 50), 8, "hline end");
    assert_eq(fb_get(9, 50), 0, "hline before");
    return 0;
}

fn test_palette() {
    render_init();
    assert_eq(pal_get_r(0), 0, "palette 0 R=0");
    assert_eq(pal_get_r(63), 255, "palette 63 R=255");
    return 0;
}

// ========= Sprite =========

fn test_sprite_blit() {
    render_init();
    fb_clear(0);
    var data[16];
    memset(&data, 0, 16);
    store8(&data + 5, 2);
    var spr = Sprite { &data, 4, 4 };
    sprite_blit(&spr, 10, 10);
    assert_eq(fb_get(11, 11), 2, "sprite blit writes pixel");
    assert_eq(fb_get(10, 10), 0, "transparent pixel unchanged");
    return 0;
}

fn test_sprite_make_player() {
    var buf[384];
    sprite_make_player(&buf, 16, 24, 16, 20);
    var body = load8(&buf + 12 * 16 + 8);
    assert_eq(body, 16, "player body is jersey");
    return 0;
}

// ========= Court =========

fn test_court_screen_y() {
    var far_y = court_game_to_screen_y(COURT_FAR);
    assert_eq(far_y, 40, "far -> screen top");
    var near_y = court_game_to_screen_y(COURT_NEAR);
    assert_eq(near_y, 210, "near -> screen bottom");
    return 0;
}

fn test_court_scale() {
    var far_scale = court_scale_at_y(COURT_FAR);
    assert_eq(far_scale, 32768, "far scale 0.5");
    var near_scale = court_scale_at_y(COURT_NEAR);
    assert(near_scale > 60000, "near scale ~1.0");
    return 0;
}

// ========= Player state machine =========

fn test_player_committed() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_try_transition(p, PS_SHOOT);
    var ptr: *i64 = p;
    assert_eq(*(ptr + 4), PS_SHOOT, "entered shoot");
    player_try_transition(p, PS_RUN);
    assert_eq(*(ptr + 4), PS_SHOOT, "shoot rejects input");
    return 0;
}

fn test_player_timer_expiry() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_try_transition(p, PS_SHOOT);
    var i = 0;
    while (i < 30) { player_tick_state(p); i = i + 1; }
    var ptr: *i64 = p;
    assert_eq(*(ptr + 4), PS_IDLE, "shoot -> idle after timer");
    return 0;
}

fn test_player_movement() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_set_stats(p, 7, 5, 8, 6, 4, 5, 6, 7, 5);
    var ptr: *i64 = p;
    var initial_x = *ptr;
    var i = 0;
    while (i < 10) {
        player_apply_input(p, 1, 0, 0);
        player_update(p);
        i = i + 1;
    }
    assert(*ptr > initial_x, "player moved right");
    return 0;
}

fn test_player_court_bounds() {
    var p = player_new(TEAM_HOME, 0, COURT_RIGHT, 8519680);
    var ptr: *i64 = p;
    *(ptr + 2) = 65536;
    player_update(p);
    assert_eq(*ptr, COURT_RIGHT, "clamped to court right");
    return 0;
}

// ========= Ball =========

fn test_ball_new() {
    var b = ball_new(6553600, 8519680);
    var bp: *i64 = b;
    assert_eq(*(bp + 6), BALL_HELD, "ball starts held");
    assert_eq(*(bp + 2), BALL_HOLD_Z, "ball at hold height");
    return 0;
}

fn test_ball_launch() {
    var b = ball_new(6553600, 8519680);
    ball_launch(b, 65536, 32768, 131072);
    var bp: *i64 = b;
    assert_eq(*(bp + 6), BALL_FLIGHT, "ball in flight after launch");
    assert_eq(*(bp + 3), 65536, "vx set");
    assert_eq(*(bp + 5), 131072, "vz set");
    return 0;
}

fn test_ball_gravity() {
    var b = ball_new(6553600, 8519680);
    ball_launch(b, 0, 0, 131072);   // straight up

    var bp: *i64 = b;
    var initial_vz = *(bp + 5);

    // Step a few frames
    var i = 0;
    while (i < 5) {
        ball_physics_step(b);
        i = i + 1;
    }

    // vz should have decreased (gravity pulls down)
    assert(*(bp + 5) < initial_vz, "gravity reduces vz");
    return 0;
}

fn test_ball_floor_bounce() {
    var b = ball_new(6553600, 8519680);
    var bp: *i64 = b;
    // Put ball at floor with downward velocity
    *(bp + 2) = 0;              // z = floor
    *(bp + 5) = 0 - 65536;     // vz = -1.0 (downward)
    *(bp + 6) = BALL_FLIGHT;

    ball_floor_check(b);

    // vz should be positive (bounced)
    assert(*(bp + 5) >= 0, "vz positive after floor bounce");
    assert_eq(*(bp + 2), 0, "z at floor after bounce");
    return 0;
}

fn test_ball_give_to() {
    var b = ball_new(6553600, 8519680);
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    ball_give_to(b, p);

    var bp: *i64 = b;
    assert_eq(*(bp + 6), BALL_HELD, "ball held after give");
    assert_eq(*(bp + 7), p, "holder set");

    var pp: *i64 = p;
    assert_eq(*(pp + 9), 1, "player has_ball");
    return 0;
}

fn test_ball_held_follows_player() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var b = ball_new(0, 0);
    ball_give_to(b, p);
    ball_update(b);

    var bp: *i64 = b;
    var pp: *i64 = p;
    // Ball should be near player position
    var dx = *bp - *pp;
    if (dx < 0) { dx = 0 - dx; }
    assert(dx < 327680, "ball follows player x");   // within 5.0
    return 0;
}

// ========= Collision =========

fn test_dist_sq() {
    var d = dist_sq(0, 0, 196608, 262144);   // (0,0) to (3,4)
    assert(d > 0, "dist_sq positive for 3-4-5 triangle");
    return 0;
}

fn test_ball_player_pickup() {
    var b = ball_new(6553600, 8519680);
    var bp: *i64 = b;
    *(bp + 6) = BALL_BOUNCE;     // loose ball
    *(bp + 2) = 0;               // on floor

    // Player right on top of ball
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var result = collision_ball_player(b, p);
    assert_eq(result, 1, "player picks up nearby ball");
    assert_eq(*(bp + 6), BALL_HELD, "ball now held");
    return 0;
}

fn test_ball_player_too_far() {
    var b = ball_new(6553600, 8519680);
    var bp: *i64 = b;
    *(bp + 6) = BALL_BOUNCE;
    *(bp + 2) = 0;

    // Player far away
    var p = player_new(TEAM_HOME, 0, 14417920, 8519680);  // (220, 130)
    var result = collision_ball_player(b, p);
    assert_eq(result, 0, "no pickup when far away");
    return 0;
}

// ========= Shooting =========

fn test_shoot_rng_determinism() {
    shoot_rng_seed(42);
    var a = shoot_rng();
    shoot_rng_seed(42);
    var b = shoot_rng();
    assert_eq(a, b, "same seed -> same value");
    return 0;
}

fn test_compute_shot() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    compute_shot(p, RIM_RIGHT_X, RIM_Y);

    // vx should be positive (shooting right)
    assert(_shot_vx > 0, "shot vx positive toward right rim");
    // vz should be positive (ball goes up)
    assert(_shot_vz > 0, "shot vz positive (upward arc)");
    return 0;
}

fn test_three_pointer() {
    // Close player: not a three
    var p_close = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 655360, RIM_Y);
    assert_eq(is_three_pointer(p_close, RIM_RIGHT_X, RIM_Y), 0, "close = 2pt");

    // Far player: three-pointer
    var p_far = player_new(TEAM_HOME, 0, 6553600, 8519680);  // (100, 130)
    assert_eq(is_three_pointer(p_far, RIM_RIGHT_X, RIM_Y), 1, "far = 3pt");
    return 0;
}

// ========= Game state =========

fn test_game_new() {
    var g = game_new();
    var gp: *i64 = g;
    assert_eq(*gp, STATE_TIPOFF, "game starts in tipoff");
    assert_eq(*(gp + 1), 1, "quarter 1");
    assert_eq(*(gp + 4), 0, "home score 0");
    assert_eq(*(gp + 5), 0, "away score 0");
    return 0;
}

fn test_game_tipoff_to_playing() {
    var g = game_new();
    var gp: *i64 = g;

    // Tick through tipoff
    var i = 0;
    while (i < TIPOFF_FRAMES + 1) {
        game_update_tipoff(g);
        i = i + 1;
    }
    assert_eq(*gp, STATE_PLAYING, "tipoff -> playing");
    return 0;
}

fn test_game_clock_seconds() {
    var g = game_new();
    var gp: *i64 = g;
    *(gp + 2) = 3600;    // 60 seconds * 60 fps
    assert_eq(game_clock_seconds(g), 60, "clock_seconds = 60");
    return 0;
}

fn test_game_turnover() {
    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_PLAYING;
    *(gp + 6) = TEAM_HOME;

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var p2 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var players[2];
    store64(&players, p1);
    store64(&players + 8, p2);

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, p1);

    game_turnover(g, b, &players, 2);

    assert_eq(*(gp + 6), TEAM_AWAY, "possession changed on turnover");
    return 0;
}

// ========= HUD =========

fn test_hud_digit() {
    render_init();
    fb_clear(0);
    hud_init_font();
    hud_draw_digit(0, 100, 100, 8, 2);

    // Digit "0" at 2x scale: top row = 111 → 6 pixels at (100-105, 100-101)
    assert_eq(fb_get(100, 100), 8, "digit 0 top-left");
    assert_eq(fb_get(104, 100), 8, "digit 0 top-right");
    return 0;
}

fn test_hud_renders() {
    render_init();
    fb_clear(0);

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var players[1];
    store64(&players, p1);

    hud_draw(42, 37, 2, 120, 18, &players, 1);

    // Top bar should have non-zero pixels
    var top_pixel = fb_get(10, 3);
    assert(top_pixel != 0, "HUD renders score area");
    return 0;
}

// ========= Steal =========

fn test_steal_close() {
    var stealer = player_new(TEAM_AWAY, 0, 6619136, 8519680);  // very close to handler
    player_set_stats(stealer, 5, 5, 5, 5, 10, 5, 5, 5, 5);    // max steal stat

    var handler = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var hp: *i64 = handler;
    *(hp + 9) = 1;     // has_ball

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, handler);

    // With steal stat 10, probability is 60%. Try multiple times.
    _steal_rng = 1;     // seed for reproducibility
    var stolen = 0;
    var attempts = 20;
    var i = 0;
    while (i < attempts) {
        // Reset state for each attempt
        ball_give_to(b, handler);
        var result = collision_try_steal(stealer, handler, b);
        if (result == 1) { stolen = stolen + 1; }
        i = i + 1;
    }
    assert(stolen > 0, "steal succeeds at least once in 20 tries with stat 10");
    assert(stolen < attempts, "steal doesn't always succeed");
    return 0;
}

fn test_steal_different_team_only() {
    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var p2 = player_new(TEAM_HOME, 1, 6619136, 8519680);   // same team
    player_set_stats(p1, 5, 5, 5, 5, 10, 5, 5, 5, 5);

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, p2);

    var result = collision_try_steal(p1, p2, b);
    assert_eq(result, 0, "can't steal from teammate");
    return 0;
}

// ========= Block =========

fn test_block_requires_shoot_state() {
    var blocker = player_new(TEAM_AWAY, 0, 6619136, 8519680);
    player_set_stats(blocker, 5, 5, 5, 5, 5, 10, 5, 5, 5);    // max block

    var shooter = player_new(TEAM_HOME, 0, 6553600, 8519680);
    // Shooter NOT in shoot state
    var sp: *i64 = shooter;
    *(sp + 4) = PS_RUN;

    var b = ball_new(6553600, 8519680);
    var result = collision_try_block(blocker, shooter, b);
    assert_eq(result, 0, "can't block non-shooter");
    return 0;
}

// ========= Pass interception =========

fn test_intercept_close() {
    var b = ball_new(10485760, 8519680);    // ball at (160, 130)
    var bp: *i64 = b;
    *(bp + 6) = BALL_FLIGHT;
    *(bp + 2) = 196608;     // z = 3.0 (catchable height)

    // Defender right on the ball path
    var defender = player_new(TEAM_AWAY, 0, 10485760, 8519680);
    var players[1];
    store64(&players, defender);

    var result = collision_check_intercept(b, &players, 1, TEAM_HOME);
    assert_eq(result, 1, "defender intercepts pass");
    assert_eq(*(bp + 6), BALL_HELD, "ball now held by interceptor");
    return 0;
}

fn test_intercept_same_team_ignored() {
    var b = ball_new(10485760, 8519680);
    var bp: *i64 = b;
    *(bp + 6) = BALL_FLIGHT;
    *(bp + 2) = 196608;

    // Same team player — should not intercept
    var teammate = player_new(TEAM_HOME, 1, 10485760, 8519680);
    var players[1];
    store64(&players, teammate);

    var result = collision_check_intercept(b, &players, 1, TEAM_HOME);
    assert_eq(result, 0, "teammate doesn't intercept own pass");
    return 0;
}

// ========= Dunk =========

fn test_can_dunk_in_range() {
    // Player near right rim with decent dunking stat
    var p = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 327680, RIM_Y);  // 5.0 from rim
    player_set_stats(p, 5, 5, 5, 8, 5, 5, 5, 5, 5);    // dunking = 8
    var pp: *i64 = p;
    *(pp + 9) = 1;     // has_ball

    assert_eq(can_dunk(p, RIM_RIGHT_X, RIM_Y), 1, "can dunk near rim with stat 8");
    return 0;
}

fn test_cant_dunk_too_far() {
    // Player far from rim
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);   // (100, 130) — far
    player_set_stats(p, 5, 5, 5, 10, 5, 5, 5, 5, 5);
    var pp: *i64 = p;
    *(pp + 9) = 1;

    assert_eq(can_dunk(p, RIM_RIGHT_X, RIM_Y), 0, "can't dunk from far away");
    return 0;
}

fn test_cant_dunk_low_stat() {
    // Player near rim but low dunking stat
    var p = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 196608, RIM_Y);
    player_set_stats(p, 5, 5, 5, 2, 5, 5, 5, 5, 5);    // dunking = 2 (below min)
    var pp: *i64 = p;
    *(pp + 9) = 1;

    assert_eq(can_dunk(p, RIM_RIGHT_X, RIM_Y), 0, "can't dunk with stat 2");
    return 0;
}

fn test_dunk_type_standard() {
    var p = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 327680, RIM_Y);
    player_set_stats(p, 5, 5, 5, 4, 5, 5, 5, 5, 5);    // dunking = 4 (below special threshold)
    var pp: *i64 = p;
    *(pp + 11) = 50;   // some turbo

    var dtype = select_dunk_type(p, RIM_RIGHT_X, RIM_Y);
    assert_eq(dtype, DUNK_STANDARD, "low stat = standard dunk");
    return 0;
}

fn test_dunk_type_tomahawk() {
    var p = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 524288, RIM_Y);   // 8.0 from rim
    player_set_stats(p, 5, 5, 5, 9, 5, 5, 5, 5, 5);    // dunking = 9
    var pp: *i64 = p;
    *(pp + 11) = 50;   // has turbo
    *(pp + 2) = 65536;  // moving right toward rim (vx > 0)

    var dtype = select_dunk_type(p, RIM_RIGHT_X, RIM_Y);
    assert_eq(dtype, DUNK_TOMAHAWK, "high stat + turbo + far = tomahawk");
    return 0;
}

fn test_dunk_type_name() {
    var name = dunk_type_name(DUNK_ALLEY_OOP);
    assert_eq(streq(name, "ALLEY-OOP!"), 1, "alley-oop name");
    return 0;
}

// ========= Goal tending =========

fn test_goal_tending_descending_near_rim() {
    var b = ball_new(RIM_RIGHT_X, RIM_Y);
    var bp: *i64 = b;
    *(bp + 2) = 655360;         // z = 10.0 (rim height)
    *(bp + 5) = 0 - 32768;     // vz = -0.5 (descending)
    *(bp + 6) = BALL_FLIGHT;

    var gt = is_goal_tending(b);
    assert_eq(gt, 2, "goal tending: descending ball near rim");
    return 0;
}

fn test_no_goal_tending_ascending() {
    var b = ball_new(RIM_RIGHT_X, RIM_Y);
    var bp: *i64 = b;
    *(bp + 2) = 655360;
    *(bp + 5) = 32768;         // vz = +0.5 (ascending)
    *(bp + 6) = BALL_FLIGHT;

    var gt = is_goal_tending(b);
    assert_eq(gt, 0, "no goal tending on ascending ball");
    return 0;
}

fn test_no_goal_tending_far() {
    var b = ball_new(6553600, 8519680);    // far from rim
    var bp: *i64 = b;
    *(bp + 2) = 655360;
    *(bp + 5) = 0 - 32768;
    *(bp + 6) = BALL_FLIGHT;

    var gt = is_goal_tending(b);
    assert_eq(gt, 0, "no goal tending far from rim");
    return 0;
}

// ========= Alley-oop =========

fn test_alley_oop_conditions() {
    // Receiver near rim, ball in flight above hold height, ball near receiver
    var receiver = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 196608, RIM_Y);
    player_set_stats(receiver, 5, 5, 5, 7, 5, 5, 5, 5, 5);

    var b = ball_new(RIM_RIGHT_X - 262144, RIM_Y);
    var bp: *i64 = b;
    *(bp + 6) = BALL_FLIGHT;
    *(bp + 2) = 524288;     // z = 8.0 (above hold height of 5.0)

    assert_eq(can_alley_oop(receiver, b, RIM_RIGHT_X, RIM_Y), 1,
              "alley-oop conditions met");
    return 0;
}

fn test_alley_oop_no_ball_flight() {
    var receiver = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 196608, RIM_Y);
    player_set_stats(receiver, 5, 5, 5, 7, 5, 5, 5, 5, 5);

    var b = ball_new(RIM_RIGHT_X - 262144, RIM_Y);
    var bp: *i64 = b;
    *(bp + 6) = BALL_HELD;    // not in flight

    assert_eq(can_alley_oop(receiver, b, RIM_RIGHT_X, RIM_Y), 0,
              "no alley-oop without flight ball");
    return 0;
}

// ========= Turbo =========

fn test_turbo_drain() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_set_stats(p, 7, 5, 8, 6, 4, 5, 6, 7, 5);
    var ptr: *i64 = p;
    var initial_turbo = *(ptr + 11);

    // Use turbo for 10 frames
    var i = 0;
    while (i < 10) {
        player_apply_input(p, 1, 0, 1);   // turbo = 1
        player_update(p);
        i = i + 1;
    }

    assert(*(ptr + 11) < initial_turbo, "turbo drains during use");
    return 0;
}

fn test_turbo_fire_infinite() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_set_stats(p, 7, 5, 8, 6, 4, 5, 6, 7, 5);
    var ptr: *i64 = p;
    *(ptr + 10) = 1;    // on_fire
    *(ptr + 11) = 50;   // start at half turbo

    // Use turbo for 10 frames while on fire
    var i = 0;
    while (i < 10) {
        player_apply_input(p, 1, 0, 1);
        i = i + 1;
    }

    // Turbo should not have drained (fire = infinite)
    assert_eq(*(ptr + 11), 50, "fire mode: turbo doesn't drain");
    return 0;
}

// ========= AI =========

fn test_ai_init_and_active() {
    ai_init();
    ai_set_active(0, 0);
    ai_set_active(1, 1);
    assert_eq(ai_is_active(0), 0, "player 0 not AI");
    assert_eq(ai_is_active(1), 1, "player 1 is AI");
    return 0;
}

fn test_ai_difficulty_setting() {
    ai_init();
    ai_set_difficulty(2, AI_DIFF_HARD);
    var s: *i64 = load64(&_ai_states + 2 * 8);
    assert_eq(*(s + 8), AI_DIFF_HARD, "difficulty set to hard");
    return 0;
}

fn test_ai_find_nearest_opponent() {
    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);      // home at (100, 130)
    var p2 = player_new(TEAM_AWAY, 0, 6619136, 8519680);      // away at (101, 130) — close
    var p3 = player_new(TEAM_AWAY, 1, 14417920, 8519680);     // away at (220, 130) — far
    var players[3];
    store64(&players, p1);
    store64(&players + 8, p2);
    store64(&players + 16, p3);

    var nearest = ai_find_nearest_opponent(p1, &players, 3);
    assert_eq(nearest, p2, "nearest opponent is the close one");
    return 0;
}

fn test_ai_find_teammate() {
    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var p2 = player_new(TEAM_HOME, 1, 6553600, 11141120);
    var p3 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var players[3];
    store64(&players, p1);
    store64(&players + 8, p2);
    store64(&players + 16, p3);

    var tm = ai_find_teammate(p1, &players, 3);
    assert_eq(tm, p2, "finds home teammate");
    return 0;
}

fn test_ai_ball_handler_offense_shoots_close() {
    // Ball handler very close to rim should eventually shoot or dunk
    ai_init();
    ai_set_active(0, 1);
    ai_set_difficulty(0, AI_DIFF_HARD);

    var p1 = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 327680, RIM_Y);  // near rim
    player_set_stats(p1, 7, 5, 9, 8, 4, 5, 6, 7, 5);  // good shooter + dunker
    var pp: *i64 = p1;
    *(pp + 9) = 1;     // has ball

    var p2 = player_new(TEAM_HOME, 1, 6553600, 11141120);
    var p3 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var p4 = player_new(TEAM_AWAY, 1, 14417920, 11141120);
    var players[4];
    store64(&players, p1);
    store64(&players + 8, p2);
    store64(&players + 16, p3);
    store64(&players + 24, p4);

    var b = ball_new(RIM_RIGHT_X - 327680, RIM_Y);
    ball_give_to(b, p1);

    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_PLAYING;
    *(gp + 6) = TEAM_HOME;   // home has possession

    // Run AI several times — with high stats near rim, should act
    _ai_rng = 42;
    var shot_or_dunk = 0;
    var i = 0;
    while (i < 50) {
        // Reset state each attempt to avoid cooldown blocking
        ball_give_to(b, p1);
        *(pp + 4) = PS_IDLE;
        *(pp + 6) = 0;
        var s: *i64 = load64(&_ai_states);
        *(s + 1) = 0;  // reset shoot cooldown

        var action = ai_update_player(p1, 0, b, g, RIM_RIGHT_X, RIM_Y,
                                       &players, 4);
        if (action == 1) { shot_or_dunk = shot_or_dunk + 1; }
        if (action == 2) { shot_or_dunk = shot_or_dunk + 1; }
        i = i + 1;
    }
    assert(shot_or_dunk > 0, "AI shoots or dunks when close to rim");
    return 0;
}

fn test_ai_defense_chases_handler() {
    // Defensive AI should move toward the ball handler
    ai_init();
    ai_set_active(0, 1);
    ai_set_difficulty(0, AI_DIFF_MEDIUM);

    // Defender far from handler
    var defender = player_new(TEAM_AWAY, 0, 14417920, 11141120);  // (220, 170)
    player_set_stats(defender, 7, 5, 5, 5, 7, 7, 5, 5, 5);

    // Handler with ball at (100, 130)
    var handler = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var hp: *i64 = handler;
    *(hp + 9) = 1;

    var p3 = player_new(TEAM_HOME, 1, 6553600, 11141120);
    var p4 = player_new(TEAM_AWAY, 1, 14417920, 8519680);

    var players[4];
    store64(&players, defender);
    store64(&players + 8, handler);
    store64(&players + 16, p3);
    store64(&players + 24, p4);

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, handler);

    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_PLAYING;
    *(gp + 6) = TEAM_HOME;   // home has possession → away defends

    var dp: *i64 = defender;
    var initial_x = *dp;

    // Run AI for 30 frames
    var i = 0;
    while (i < 30) {
        ai_update_player(defender, 0, b, g, RIM_LEFT_X, RIM_Y,
                          &players, 4);
        player_update(defender);
        i = i + 1;
    }

    // Defender should have moved toward handler (leftward, lower x)
    assert(*dp < initial_x, "defensive AI moves toward ball handler");
    return 0;
}

fn test_ai_off_ball_moves() {
    // Off-ball teammate should move (not stay frozen)
    ai_init();
    ai_set_active(1, 1);

    var handler = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var hp: *i64 = handler;
    *(hp + 9) = 1;

    var teammate = player_new(TEAM_HOME, 1, 6553600, 11141120);  // (100, 170)
    var p3 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var p4 = player_new(TEAM_AWAY, 1, 14417920, 11141120);

    var players[4];
    store64(&players, handler);
    store64(&players + 8, teammate);
    store64(&players + 16, p3);
    store64(&players + 24, p4);

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, handler);

    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_PLAYING;
    *(gp + 6) = TEAM_HOME;

    var tp: *i64 = teammate;
    var initial_x = *tp;
    var initial_y = *(tp + 1);

    var i = 0;
    while (i < 30) {
        ai_update_player(teammate, 1, b, g, RIM_RIGHT_X, RIM_Y,
                          &players, 4);
        player_update(teammate);
        i = i + 1;
    }

    // Teammate should have moved somewhere
    var moved_x = *tp - initial_x;
    if (moved_x < 0) { moved_x = 0 - moved_x; }
    var moved_y = *(tp + 1) - initial_y;
    if (moved_y < 0) { moved_y = 0 - moved_y; }
    assert(moved_x + moved_y > 0, "off-ball AI teammate moves");
    return 0;
}

fn test_ai_inactive_does_nothing() {
    ai_init();
    ai_set_active(0, 0);   // not AI controlled

    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var pp: *i64 = p;
    *(pp + 9) = 1;

    var b = ball_new(6553600, 8519680);
    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_PLAYING;
    *(gp + 6) = TEAM_HOME;

    var players[1];
    store64(&players, p);

    var action = ai_update_player(p, 0, b, g, RIM_RIGHT_X, RIM_Y, &players, 1);
    assert_eq(action, 0, "inactive AI takes no action");
    return 0;
}

fn test_ai_adjust_prob_difficulty() {
    var easy = ai_adjust_prob(60, AI_DIFF_EASY);
    var medium = ai_adjust_prob(60, AI_DIFF_MEDIUM);
    var hard = ai_adjust_prob(60, AI_DIFF_HARD);

    assert_eq(easy, 30, "easy halves probability");
    assert_eq(medium, 60, "medium keeps probability");
    assert_eq(hard, 90, "hard multiplies probability 1.5x");
    return 0;
}

fn test_ai_direction_to() {
    // Target to the right and below
    ai_direction_to(0, 0, 655360, 655360);    // (0,0) -> (10, 10)
    assert_eq(_ai_move_dx, 1, "direction dx = right");
    assert_eq(_ai_move_dy, 1, "direction dy = down");

    // Target to the left
    ai_direction_to(655360, 0, 0, 0);         // (10, 0) -> (0, 0)
    assert_eq(_ai_move_dx, -1, "direction dx = left");
    assert_eq(_ai_move_dy, 0, "direction dy = none");
    return 0;
}

fn test_ai_is_player_open() {
    // Player far from all opponents → open
    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);      // (100, 130)
    var p2 = player_new(TEAM_AWAY, 0, 14417920, 8519680);     // (220, 130) — far away
    var players[2];
    store64(&players, p1);
    store64(&players + 8, p2);

    assert_eq(ai_is_player_open(p1, &players, 2), 1, "player open when defenders far");

    // Player close to opponent → not open
    var p3 = player_new(TEAM_AWAY, 1, 6619136, 8519680);      // (101, 130) — very close
    var players2[3];
    store64(&players2, p1);
    store64(&players2 + 8, p2);
    store64(&players2 + 16, p3);

    assert_eq(ai_is_player_open(p1, &players2, 3), 0, "player not open when defender close");
    return 0;
}

// ========= Inbound =========

fn test_inbound_after_dead_ball() {
    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_PLAYING;
    *(gp + 6) = TEAM_HOME;    // home possession

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var p2 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var players[2];
    store64(&players, p1);
    store64(&players + 8, p2);

    var b = ball_new(6553600, 8519680);

    game_start_inbound(g, b, &players, 2);

    assert_eq(*gp, STATE_INBOUND, "dead ball triggers inbound state");
    assert(*(gp + 7) > 0, "inbound has timer");
    return 0;
}

fn test_inbound_gives_ball_to_team() {
    var g = game_new();
    var gp: *i64 = g;
    *(gp + 6) = TEAM_AWAY;    // away receives

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var p2 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var players[2];
    store64(&players, p1);
    store64(&players + 8, p2);

    var b = ball_new(6553600, 8519680);
    game_start_inbound(g, b, &players, 2);

    var bp: *i64 = b;
    assert_eq(*(bp + 6), BALL_HELD, "ball held after inbound");

    var p2p: *i64 = p2;
    assert_eq(*(p2p + 9), 1, "away player has ball after inbound");
    return 0;
}

fn test_inbound_timer_resumes_play() {
    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_INBOUND;
    *(gp + 7) = 1;            // 1 frame left

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var players[1];
    store64(&players, p1);
    var b = ball_new(6553600, 8519680);

    game_update_inbound(g, b, &players, 1);
    assert_eq(*gp, STATE_PLAYING, "inbound timer expires -> playing");
    return 0;
}

// ========= Rebound =========

fn test_rebound_near_rim() {
    // Ball bouncing near rim, two players nearby — one should get it
    var b = ball_new(RIM_RIGHT_X, RIM_Y);
    var bp: *i64 = b;
    *(bp + 6) = BALL_BOUNCE;
    *(bp + 2) = 131072;       // z = 2.0 (low, grabbable)

    var p1 = player_new(TEAM_HOME, 0, RIM_RIGHT_X - 196608, RIM_Y);
    player_set_stats(p1, 5, 5, 5, 5, 5, 5, 5, 5, 9);   // high rebound

    var p2 = player_new(TEAM_AWAY, 0, RIM_RIGHT_X + 196608, RIM_Y);
    player_set_stats(p2, 5, 5, 5, 5, 5, 5, 5, 5, 2);   // low rebound

    var players[2];
    store64(&players, p1);
    store64(&players + 8, p2);

    _rebound_rng = 12345;
    var winner = collision_check_rebound(b, &players, 2);
    assert(winner != 0, "someone wins the rebound near rim");
    assert_eq(*(bp + 6), BALL_HELD, "ball held after rebound");
    return 0;
}

fn test_rebound_far_from_rim() {
    // Ball bouncing far from rim — no rebound contest
    var b = ball_new(6553600, 8519680);    // far from both rims
    var bp: *i64 = b;
    *(bp + 6) = BALL_BOUNCE;
    *(bp + 2) = 131072;

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var players[1];
    store64(&players, p1);

    var winner = collision_check_rebound(b, &players, 1);
    assert_eq(winner, 0, "no rebound far from rim");
    return 0;
}

// ========= Clutch =========

fn test_clutch_boosts_stats() {
    var g = game_new();

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_set_stats(p1, 5, 5, 5, 5, 5, 5, 5, 8, 5);   // clutch = 8
    var pp: *i64 = p1;
    var shooting_before = *(pp + 19);

    var players[1];
    store64(&players, p1);

    game_apply_clutch(g, &players, 1);

    assert(*(pp + 19) > shooting_before, "clutch boosts shooting");
    assert(*(pp + 17) > 5, "clutch boosts speed");
    return 0;
}

fn test_clutch_capped_at_10() {
    var g = game_new();

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_set_stats(p1, 10, 5, 10, 5, 10, 10, 5, 10, 5);   // max stats, high clutch
    var pp: *i64 = p1;

    var players[1];
    store64(&players, p1);

    game_apply_clutch(g, &players, 1);

    assert_eq(*(pp + 19), 10, "shooting capped at 10 after clutch");
    assert_eq(*(pp + 17), 10, "speed capped at 10 after clutch");
    return 0;
}

// ========= Fouls =========

fn test_foul_changes_possession() {
    var g = game_new();
    var gp: *i64 = g;
    *gp = STATE_PLAYING;
    *(gp + 6) = TEAM_HOME;

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var p2 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var players[2];
    store64(&players, p1);
    store64(&players + 8, p2);

    var b = ball_new(6553600, 8519680);
    ball_give_to(b, p1);

    // Home commits foul
    game_call_foul(g, TEAM_HOME, b, &players, 2);

    assert_eq(*gp, STATE_FOUL, "foul triggers foul state");
    assert_eq(*(gp + 6), TEAM_AWAY, "foul gives possession to fouled team");
    assert_eq(*(gp + 13), 1, "home foul count incremented");
    return 0;
}

fn test_push_foul_detection() {
    push_init();
    _push_init_done = 0;   // force re-init
    push_init();

    // Simulate repeated pushes
    var i = 0;
    var foul = 0;
    while (i < PUSH_FOUL_THRESHOLD) {
        foul = push_record(0, 2, TEAM_HOME);
        i = i + 1;
    }
    assert_eq(foul, 1, "repeated pushes trigger foul");
    assert_eq(push_get_foul_team(), TEAM_HOME, "foul team is the pusher");
    return 0;
}

// ========= Auto-switch =========

fn test_auto_switch_find_nearest() {
    var b = ball_new(14417920, 8519680);    // ball at (220, 130)

    var p1 = player_new(TEAM_HOME, 0, 6553600, 8519680);     // (100, 130) — far
    var p2 = player_new(TEAM_HOME, 1, 13107200, 8519680);    // (200, 130) — near ball
    var p3 = player_new(TEAM_AWAY, 0, 14417920, 8519680);
    var players[3];
    store64(&players, p1);
    store64(&players + 8, p2);
    store64(&players + 16, p3);

    var idx = game_find_nearest_on_team(b, &players, 3, TEAM_HOME);
    assert_eq(idx, 1, "nearest home player to ball is index 1");
    return 0;
}

// ========= PS_REBOUND state =========

fn test_rebound_is_committed() {
    assert_eq(player_is_committed(PS_REBOUND), 1, "REBOUND is committed state");
    return 0;
}

fn test_rebound_timer() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_try_transition(p, PS_REBOUND);
    var pp: *i64 = p;
    assert_eq(*(pp + 4), PS_REBOUND, "entered rebound state");
    assert_eq(*(pp + 6), REBOUND_FRAMES, "rebound timer set");
    return 0;
}

// ========= Integration =========

fn test_court_render_pixels() {
    render_init();
    fb_clear(0);
    court_draw();
    var pixels = render_pixel_count();
    assert(pixels > 10000, "court >10000 pixels");
    return 0;
}

fn test_full_frame() {
    render_init();
    fb_clear(0);
    court_draw();

    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var pp: *i64 = p;
    *(pp + 14) = 0;     // no sprite, use fallback
    player_draw(p);

    var b = ball_new(10485760, 6553600);
    ball_draw(b);

    var pixels = render_pixel_count();
    assert(pixels > 12000, "full frame > 12000 pixels");
    return 0;
}

// ========= Main =========

fn main() {
    alloc_init();

    // Physics
    test_ball_arc();

    // Fire
    test_fire_activation();
    test_fire_extinguish();

    // Stats
    test_stat_range();

    // Render
    test_fb_clear();
    test_fb_set_get();
    test_fb_bounds();
    test_draw_hline();
    test_palette();

    // Sprite
    test_sprite_blit();
    test_sprite_make_player();

    // Court
    test_court_screen_y();
    test_court_scale();

    // Player
    test_player_committed();
    test_player_timer_expiry();
    test_player_movement();
    test_player_court_bounds();

    // Ball
    test_ball_new();
    test_ball_launch();
    test_ball_gravity();
    test_ball_floor_bounce();
    test_ball_give_to();
    test_ball_held_follows_player();

    // Collision
    test_dist_sq();
    test_ball_player_pickup();
    test_ball_player_too_far();

    // Shooting
    test_shoot_rng_determinism();
    test_compute_shot();
    test_three_pointer();

    // Game state
    test_game_new();
    test_game_tipoff_to_playing();
    test_game_clock_seconds();
    test_game_turnover();

    // HUD
    test_hud_digit();
    test_hud_renders();

    // Dunk
    test_can_dunk_in_range();
    test_cant_dunk_too_far();
    test_cant_dunk_low_stat();
    test_dunk_type_standard();
    test_dunk_type_tomahawk();
    test_dunk_type_name();

    // Goal tending
    test_goal_tending_descending_near_rim();
    test_no_goal_tending_ascending();
    test_no_goal_tending_far();

    // Alley-oop
    test_alley_oop_conditions();
    test_alley_oop_no_ball_flight();

    // Steal
    test_steal_close();
    test_steal_different_team_only();

    // Block
    test_block_requires_shoot_state();

    // Interception
    test_intercept_close();
    test_intercept_same_team_ignored();

    // Turbo
    test_turbo_drain();
    test_turbo_fire_infinite();

    // AI
    test_ai_init_and_active();
    test_ai_difficulty_setting();
    test_ai_find_nearest_opponent();
    test_ai_find_teammate();
    test_ai_ball_handler_offense_shoots_close();
    test_ai_defense_chases_handler();
    test_ai_off_ball_moves();
    test_ai_inactive_does_nothing();
    test_ai_adjust_prob_difficulty();
    test_ai_direction_to();
    test_ai_is_player_open();

    // Inbound
    test_inbound_after_dead_ball();
    test_inbound_gives_ball_to_team();
    test_inbound_timer_resumes_play();

    // Rebound
    test_rebound_near_rim();
    test_rebound_far_from_rim();

    // Clutch
    test_clutch_boosts_stats();
    test_clutch_capped_at_10();

    // Fouls
    test_foul_changes_possession();
    test_push_foul_detection();

    // Auto-switch
    test_auto_switch_find_nearest();

    // PS_REBOUND
    test_rebound_is_committed();
    test_rebound_timer();

    // Integration
    test_court_render_pixels();
    test_full_frame();

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
