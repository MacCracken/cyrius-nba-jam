// cyrius-nba-jam — test suite
// Tests for: physics, fire mechanic, stats, render, sprite, court,
// player state machine, player movement.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"

include "src/types.cyr"
include "src/render.cyr"
include "src/sprite.cyr"
include "src/court.cyr"
include "src/player.cyr"

// ========= Ball physics =========

fn test_ball_arc() {
    // Ball at y=100, velocity_y=-20 (upward)
    // After gravity, velocity_y should increase (less negative)
    var y = 100 * 65536;
    var vy = 0 - (20 * 65536);
    var gravity = BALL_GRAVITY;

    var i = 0;
    while (i < 10) {
        vy = vy + gravity;
        y = y + vy;
        i = i + 1;
    }

    assert(vy > (0 - (20 * 65536)), "gravity slows upward velocity");
    return 0;
}

// ========= Fire mechanic =========

fn test_fire_activation() {
    var consecutive = 0;
    consecutive = consecutive + 1;
    consecutive = consecutive + 1;
    consecutive = consecutive + 1;

    var on_fire = 0;
    if (consecutive >= FIRE_BASKETS_NEEDED) {
        on_fire = 1;
    }
    assert(on_fire == 1, "3 consecutive baskets activate fire");
    return 0;
}

fn test_fire_extinguish() {
    var on_fire = 1;
    var opponent_scored = 1;
    if (opponent_scored == 1) { on_fire = 0; }
    assert(on_fire == 0, "opponent scoring extinguishes fire");
    return 0;
}

// ========= Stats =========

fn test_stat_range() {
    var stats[9];
    store64(&stats, 7);       // speed
    store64(&stats + 8, 4);   // power
    store64(&stats + 16, 9);  // shooting
    store64(&stats + 24, 8);  // dunking
    store64(&stats + 32, 3);  // stealing
    store64(&stats + 40, 5);  // blocking
    store64(&stats + 48, 6);  // pass
    store64(&stats + 56, 10); // clutch
    store64(&stats + 64, 5);  // rebound

    var i = 0;
    while (i < STAT_COUNT) {
        var val = load64(&stats + i * 8);
        assert(val >= 1, "stat >= 1");
        assert(val <= 10, "stat <= 10");
        i = i + 1;
    }
    return 0;
}

// ========= Render =========

fn test_fb_clear() {
    render_init();
    fb_clear(42);
    assert_eq(fb_get(0, 0), 42, "clear fills (0,0)");
    assert_eq(fb_get(160, 120), 42, "clear fills center");
    assert_eq(fb_get(319, 239), 42, "clear fills last pixel");
    fb_clear(0);
    return 0;
}

fn test_fb_set_get() {
    render_init();
    fb_clear(0);
    fb_set(100, 100, 7);
    assert_eq(fb_get(100, 100), 7, "set/get pixel");
    assert_eq(fb_get(101, 100), 0, "adjacent pixel unchanged");
    return 0;
}

fn test_fb_bounds() {
    render_init();
    fb_clear(0);
    // Out of bounds should return 0 and not crash
    assert_eq(fb_get(-1, 0), 0, "negative x returns 0");
    assert_eq(fb_get(0, -1), 0, "negative y returns 0");
    assert_eq(fb_get(320, 0), 0, "x >= width returns 0");
    assert_eq(fb_get(0, 240), 0, "y >= height returns 0");

    // Set out of bounds should not crash
    fb_set(-1, 0, 99);
    fb_set(320, 0, 99);
    fb_set(0, 240, 99);
    return 0;
}

fn test_draw_hline() {
    render_init();
    fb_clear(0);
    draw_hline(10, 20, 50, 8);
    assert_eq(fb_get(10, 50), 8, "hline start");
    assert_eq(fb_get(15, 50), 8, "hline mid");
    assert_eq(fb_get(20, 50), 8, "hline end");
    assert_eq(fb_get(9, 50), 0, "hline before start");
    assert_eq(fb_get(21, 50), 0, "hline after end");
    return 0;
}

fn test_draw_rect() {
    render_init();
    fb_clear(0);
    draw_rect(50, 50, 10, 10, 5);
    assert_eq(fb_get(50, 50), 5, "rect top-left");
    assert_eq(fb_get(55, 55), 5, "rect center");
    assert_eq(fb_get(59, 59), 5, "rect bottom-right");
    assert_eq(fb_get(60, 60), 0, "rect outside");
    return 0;
}

fn test_palette() {
    render_init();
    // Check palette values
    assert_eq(pal_get_r(0), 0, "palette 0 R=0");
    assert_eq(pal_get_g(0), 0, "palette 0 G=0");
    assert_eq(pal_get_b(0), 0, "palette 0 B=0");
    assert_eq(pal_get_r(63), 255, "palette 63 R=255");
    assert_eq(pal_get_g(63), 255, "palette 63 G=255");
    assert_eq(pal_get_b(63), 255, "palette 63 B=255");
    return 0;
}

// ========= Sprite =========

fn test_sprite_blit() {
    render_init();
    fb_clear(0);

    // Create a 4x4 test sprite
    var data[16];
    memset(&data, 0, 16);
    store8(&data + 5, 2);      // pixel at (1,1) = color 2
    store8(&data + 6, 2);      // pixel at (2,1) = color 2

    var spr = Sprite { &data, 4, 4 };
    sprite_blit(&spr, 10, 10);

    assert_eq(fb_get(11, 11), 2, "sprite blit writes pixel");
    assert_eq(fb_get(10, 10), 0, "sprite transparent pixel");
    return 0;
}

fn test_sprite_clipping() {
    render_init();
    fb_clear(0);

    // Sprite at edge of screen
    var data[16];
    memset(&data, 0, 16);
    store8(&data + 5, 3);

    var spr = Sprite { &data, 4, 4 };
    sprite_blit(&spr, 318, 0);

    // Should not crash, and visible pixels should be drawn
    // Pixel at (319, 1) = sprite col 1, row 1 = color 3
    assert_eq(fb_get(319, 1), 3, "clipped sprite visible at edge");
    return 0;
}

fn test_sprite_make_player() {
    // Generate placeholder player sprite
    var buf[384];   // 16*24 = 384 bytes
    sprite_make_player(&buf, 16, 24, 16, 20);

    // Head area (top quarter, centered) should be skin color
    var head_pixel = load8(&buf + 1 * 16 + 6);  // row 1, col 6
    assert_eq(head_pixel, 20, "player head is skin color");

    // Body area should be jersey color
    var body_pixel = load8(&buf + 12 * 16 + 8);  // row 12, col 8
    assert_eq(body_pixel, 16, "player body is jersey color");
    return 0;
}

// ========= Court =========

fn test_court_screen_y() {
    // Far baseline (COURT_FAR = 50.0 = 3276800) → screen top (40)
    var far_y = court_game_to_screen_y(COURT_FAR);
    assert_eq(far_y, 40, "far baseline maps to screen top");

    // Near baseline (COURT_NEAR = 225.0 = 14745600) → screen bottom (210)
    var near_y = court_game_to_screen_y(COURT_NEAR);
    assert_eq(near_y, 210, "near baseline maps to screen bottom");
    return 0;
}

fn test_court_scale() {
    // At far end: scale = 0.5 (32768 in 16.16)
    var far_scale = court_scale_at_y(COURT_FAR);
    assert_eq(far_scale, 32768, "far scale is 0.5");

    // At near end: scale ≈ 1.0 (65536 in 16.16)
    var near_scale = court_scale_at_y(COURT_NEAR);
    assert(near_scale > 60000, "near scale is near 1.0");
    assert(near_scale <= 65536, "near scale <= 1.0");
    return 0;
}

fn test_court_center_x() {
    // Center court X (160.0) at center Y should map near screen center
    var mid_y = (COURT_FAR + COURT_NEAR) / 2;     // 137.5 in fixed-point
    var center_x = court_game_to_screen_x(RIM_X, mid_y);
    assert(center_x > 140, "center X > 140");
    assert(center_x < 180, "center X < 180");
    return 0;
}

// ========= Player state machine =========

fn test_player_idle_to_run() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_try_transition(p, PS_RUN);
    var ptr: *i64 = p;
    assert_eq(*(ptr + 4), PS_RUN, "idle -> run");
    return 0;
}

fn test_player_committed_state() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_try_transition(p, PS_SHOOT);
    var ptr: *i64 = p;
    assert_eq(*(ptr + 4), PS_SHOOT, "entered shoot state");
    assert_eq(*(ptr + 6), 30, "shoot timer = 30 frames");

    // Try to run during shoot — should be rejected
    player_try_transition(p, PS_RUN);
    assert_eq(*(ptr + 4), PS_SHOOT, "shoot rejects run input");
    return 0;
}

fn test_player_timer_expiry() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    player_try_transition(p, PS_SHOOT);

    var i = 0;
    while (i < 30) {
        player_tick_state(p);
        i = i + 1;
    }

    var ptr: *i64 = p;
    assert_eq(*(ptr + 4), PS_IDLE, "shoot -> idle after timer");
    assert_eq(*(ptr + 6), 0, "timer is zero");
    return 0;
}

// ========= Player movement =========

fn test_player_movement() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);    // (100.0, 130.0)
    player_set_stats(p, 7, 5, 8, 6, 4, 5, 6, 7, 5);

    var ptr: *i64 = p;
    var initial_x = *ptr;

    // Apply rightward input for 10 frames
    var i = 0;
    while (i < 10) {
        player_apply_input(p, 1, 0, 0);
        player_update(p);
        i = i + 1;
    }

    // X should have increased
    assert(*ptr > initial_x, "player moved right");
    return 0;
}

fn test_player_court_bounds() {
    // Place player at right edge
    var p = player_new(TEAM_HOME, 0, COURT_RIGHT, 8519680);
    var ptr: *i64 = p;

    // Push rightward
    *(ptr + 2) = 65536;    // vx = 1.0
    player_update(p);

    // Should be clamped to court right
    assert_eq(*ptr, COURT_RIGHT, "player clamped to court right");
    assert_eq(*(ptr + 2), 0, "velocity zeroed at boundary");
    return 0;
}

fn test_player_facing() {
    var p = player_new(TEAM_HOME, 0, 6553600, 8519680);
    var ptr: *i64 = p;

    player_apply_input(p, 1, 0, 0);   // right
    assert_eq(*(ptr + 13), 2, "facing right");

    player_apply_input(p, -1, 0, 0);  // left
    assert_eq(*(ptr + 13), 6, "facing left");

    player_apply_input(p, 0, -1, 0);  // up
    assert_eq(*(ptr + 13), 0, "facing up");

    player_apply_input(p, 1, -1, 0);  // up-right
    assert_eq(*(ptr + 13), 1, "facing up-right");
    return 0;
}

// ========= Pixel count =========

fn test_court_render_pixels() {
    render_init();
    fb_clear(0);
    court_draw();
    var pixels = render_pixel_count();
    assert(pixels > 10000, "court renders >10000 pixels");
    assert(pixels < 76800, "court doesn't fill entire screen");
    return 0;
}

// ========= Main =========

fn main() {
    alloc_init();

    // Ball physics
    test_ball_arc();

    // Fire mechanic
    test_fire_activation();
    test_fire_extinguish();

    // Stats
    test_stat_range();

    // Render
    test_fb_clear();
    test_fb_set_get();
    test_fb_bounds();
    test_draw_hline();
    test_draw_rect();
    test_palette();

    // Sprite
    test_sprite_blit();
    test_sprite_clipping();
    test_sprite_make_player();

    // Court
    test_court_screen_y();
    test_court_scale();
    test_court_center_x();

    // Player state machine
    test_player_idle_to_run();
    test_player_committed_state();
    test_player_timer_expiry();

    // Player movement
    test_player_movement();
    test_player_court_bounds();
    test_player_facing();

    // Integration
    test_court_render_pixels();

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
